# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# For local development with MongoDB Community:
# MONGO_URI=mongodb://localhost:27017/db_locker
# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/db_locker
MONGO_URI=mongodb://localhost:27017/db_locker

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024

# Encryption Configuration (AES-256-CBC)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Google OAuth (Optional - for production)
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
